generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Upload {
  id           String        @id @default(cuid())
  filename     String
  source       String        // "nab" | "wise"
  rowCount     Int?
  status       String        @default("pending")
  errorMsg     String?
  createdAt    DateTime      @default(now())
  completedAt  DateTime?
  transactions Transaction[]
}

model Transaction {
  id                 String                  @id @default(cuid())
  source             String                  // "nab" | "wise"
  uploadId           String?
  upload             Upload?                 @relation(fields: [uploadId], references: [id])
  date               DateTime
  amount             Float
  balance            Float?
  transactionType    String?
  transactionDetails String?
  merchantName       String?
  accountNumber      String?
  category           String?
  subcategory        String?
  categorySource     String?                 // "llm" | "manual" | "rule" | "csv_import"
  categoryConfidence Float?
  dedupHash          String?                 @unique
  rdEligible         Boolean                 @default(false)
  rdPercentage       Float?
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  processedOn        DateTime?
  attachments        TransactionAttachment[]

  @@index([date])
  @@index([category])
  @@index([source])
}

model SubcategoryRdConfig {
  id          String @id @default(cuid())
  category    String
  subcategory String
  rdPercent   Float  @default(0)

  @@unique([category, subcategory])
}

model TransactionAttachment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  filename      String
  storedPath    String
  fileSize      Int?
  uploadedAt    DateTime    @default(now())
}

model CategoryRule {
  id          String   @id @default(cuid())
  pattern     String
  category    String
  subcategory String?
  learnedFrom String?
  createdAt   DateTime @default(now())
}

model ForecastOverride {
  id                  String   @id @default(cuid())
  category            String
  subcategory         String
  customLabel         String?  // display label for a custom subcategory
  customCategoryLabel String?  // set only for fully custom (forecast-only) categories
  month               String   // "YYYY-MM"
  amount              Float    // same sign convention as transactions (negative = expense)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([category, subcategory, month])
  @@index([month])
}

model ForecastScenario {
  id        String   @id @default(cuid())
  name      String
  snapshot  String   // JSON array of ForecastOverride rows
  createdAt DateTime @default(now())
}

// ─── Contractor Management Module ────────────────────────────────────────────

model User {
  id         String        @id @default(cuid())
  email      String        @unique
  name       String?
  role       String        @default("contractor") // "admin" | "contractor"
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  contractor Contractor?
  sessions   UserSession[]
  otpTokens  OtpToken[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA256(jti) — enables revocation without exposing secret
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   // 6-digit string
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Contractor {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  dailyRate     Float
  currency      String         @default("AUD")
  startDate     DateTime
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leaveRequests LeaveRequest[]
  payslips      Payslip[]
}

model LeaveRequest {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  leaveDate    DateTime   // single day per record
  reason       String
  status       String     @default("pending") // "pending" | "approved" | "denied"
  adminNote    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([contractorId])
  @@index([status])
}

model Payslip {
  id            String     @id @default(cuid())
  contractorId  String
  contractor    Contractor @relation(fields: [contractorId], references: [id])
  periodMonth   Int        // 1–12
  periodYear    Int
  workingDays   Int        // Mon–Fri in period (pro-rated if start date mid-month)
  leaveDays     Int        // approved Mon–Fri leave days deducted
  billableDays  Int        // workingDays - leaveDays
  dailyRateSnap Float      // snapshot at generation time
  grossAmount   Float      // workingDays × dailyRateSnap
  deductions    Float      // leaveDays × dailyRateSnap
  netAmount     Float      // billableDays × dailyRateSnap
  paymentStatus String     @default("pending") // "pending" | "paid"
  paidAmount    Float?
  paidAt        DateTime?
  generatedAt   DateTime   @default(now())

  @@unique([contractorId, periodMonth, periodYear])
  @@index([contractorId])
  @@index([paymentStatus])
}
